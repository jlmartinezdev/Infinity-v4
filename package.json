{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "scripts": {
        "dev": "npm run development",
        "development": "mix",
        "watch": "mix watch",
        "build": "npm run production",
        "production": "mix --production",
        "build:watch": "mix watch --production",
        "compile": "mix",
        "clean": "echo Limpiando archivos compilados... && mix --production",
        "start": "npm run watch",
        "serve": "php artisan serve --port=8000",
        "serve:host": "php artisan serve --host=0.0.0.0 --port=8000",
        "migrate": "php artisan migrate",
        "migrate:fresh": "php artisan migrate:fresh",
        "migrate:rollback": "php artisan migrate:rollback",
        "dev:all": "concurrently \"npm run watch\" \"npm run serve\"",
        "dev:all:host": "concurrently \"npm run watch\" \"npm run serve:host\""
    },
    "devDependencies": {
        "@babel/core": "^7.23.0",
        "@babel/preset-env": "^7.23.0",
        "autoprefixer": "^10.4.16",
        "axios": "^1.11.0",
        "babel-loader": "^9.1.3",
        "concurrently": "^9.0.1",
        "css-loader": "^6.8.1",
        "laravel-mix": "^6.0.49",
        "mini-css-extract-plugin": "^2.7.6",
        "postcss": "^8.4.31",
        "postcss-loader": "^7.3.3",
        "tailwindcss": "^3.4.3",
        "vue-loader": "^17.3.1",
        "webpack": "^5.89.0",
        "webpack-cli": "^5.1.4"
    },
    "dependencies": {
        "html2canvas": "^1.4.1",
        "sweetalert2": "^11.26.17",
        "vue": "^3.5.26"
    }
}
